{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "pairs/{SYMBOL}.json (per-pair history, v1.0.0)",
  "type": "object",
  "required": ["symbol", "schema_version", "history"],
  "properties": {
    "symbol": {"type": "string"},
    "display_symbol": {"type": "string"},
    "schema_version": {"type": "string", "const": "1.0.0"},
    "current": {
      "type": "object",
      "properties": {
        "signal": {"type": ["string", "null"], "enum": ["BUY", "SELL", null]},
        "signal_source": {"type": ["string", "null"], "enum": ["primary", "secondary", null]},
        "signal_started_date": {"type": ["string", "null"]},
        "signal_trading_days": {"type": ["integer", "null"], "minimum": 0},
        "position_strength": {
          "type": ["string", "null"],
          "enum": ["Strong", "Moderate", "Close to flipping", null]
        },
        "peak_gain_pct": {"type": ["number", "null"], "minimum": 0.0}
      }
    },
    "metrics": {
      "type": "object",
      "required": ["trade_count"],
      "properties": {
        "trade_count": {"type": "integer", "minimum": 0},
        "avg_hold_days": {"type": ["number", "null"]},
        "avg_gain_pct": {"type": ["number", "null"]},
        "avg_peak_gain_pct": {"type": ["number", "null"], "minimum": 0.0},
        "success_rate": {"type": ["number", "null"], "minimum": 0.0, "maximum": 1.0}
      }
    },
    "history": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["date", "close", "signal"],
        "properties": {
          "date": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"},
          "close": {"type": ["number", "null"]},
          "signal": {"type": ["string", "null"], "enum": ["BUY", "SELL", null]},
          "psar": {"type": ["number", "null"]}
        },
        "additionalProperties": false
      }
    }
  }
}
